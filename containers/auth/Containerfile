FROM docker.io/python:3.12-slim
LABEL org.opencontainers.image.title="hermes-agent-auth"
LABEL org.opencontainers.image.description="Authentication proxy for Hermes dashboard publishing"

ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1

RUN pip install --no-cache-dir \
    fastapi==0.115.12 \
    httpx==0.28.1 \
    itsdangerous==2.2.0 \
    ldap3==2.9.1 \
    uvicorn[standard]==0.34.2

WORKDIR /app
COPY authproxy.py /app/authproxy.py

CMD ["python", "/app/authproxy.py"]