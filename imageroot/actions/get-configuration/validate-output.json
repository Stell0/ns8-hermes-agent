{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "get-configuration output",
    "$id": "http://schema.nethserver.org/hermes-agent/get-configuration-output.json",
    "description": "Get hermes-agent configuration",
    "examples": [],
    "type": "object",
    "additionalProperties": false,
    "required": [
        "agents",
        "openviking"
    ],
    "properties": {
        "agents": {
            "type": "array",
            "items": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                    "id",
                    "name",
                    "role",
                    "status"
                ],
                "properties": {
                    "id": {
                        "type": "integer",
                        "minimum": 0
                    },
                    "name": {
                        "type": "string",
                        "minLength": 1,
                        "pattern": "^[A-Za-z ]+$"
                    },
                    "role": {
                        "type": "string",
                        "enum": [
                            "default",
                            "developer"
                        ]
                    },
                    "status": {
                        "type": "string",
                        "enum": [
                            "start",
                            "stop"
                        ]
                    },
                    "account": {
                        "type": "string",
                        "minLength": 1,
                        "pattern": "^[A-Za-z0-9][A-Za-z0-9_-]*$"
                    },
                    "user": {
                        "type": "string",
                        "minLength": 1,
                        "pattern": "^[A-Za-z0-9][A-Za-z0-9_-]*$"
                    },
                    "agent_id": {
                        "type": "string",
                        "minLength": 1,
                        "pattern": "^[A-Za-z0-9][A-Za-z0-9_-]*$"
                    },
                    "hidden": {
                        "type": "boolean"
                    },
                    "protected": {
                        "type": "boolean"
                    },
                    "system": {
                        "type": "boolean"
                    },
                    "use_default_gateway_for_llm": {
                        "type": "boolean"
                    }
                }
            }
        },
        "openviking": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "embedding"
            ],
            "properties": {
                "embedding": {
                    "type": "object",
                    "additionalProperties": false,
                    "required": [
                        "api_key_configured"
                    ],
                    "properties": {
                        "provider": {
                            "type": "string",
                            "enum": [
                                "gemini",
                                "jina",
                                "minimax",
                                "openai",
                                "volcengine",
                                "voyage"
                            ]
                        },
                        "api_key_configured": {
                            "type": "boolean"
                        }
                    }
                }
            }
        }
    }
}