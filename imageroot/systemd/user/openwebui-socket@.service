[Unit]
Description=Open WebUI unix socket sidecar %i
Requires=hermes-pod@%i.service openwebui@%i.service
After=hermes-pod@%i.service openwebui@%i.service
PartOf=openwebui@%i.service

[Service]
Environment=PODMAN_SYSTEMD_UNIT=%n
EnvironmentFile=-%S/state/environment
EnvironmentFile=-%S/state/agent_%i.env
WorkingDirectory=%S/state
Restart=on-failure
KillMode=none
Type=notify
NotifyAccess=all
ExecStartPre=/usr/bin/install -d -m 0770 %S/state/dashboard-sockets
ExecStartPre=-/usr/bin/rm -f %S/state/dashboard-sockets/agent-%i-chat.sock
ExecStartPre=-/usr/bin/podman rm --force openwebui-socket-%i
ExecStart=runagent /usr/bin/podman run \
		--name openwebui-socket-%i \
		--replace \
		--rm \
		--sdnotify=conmon \
		--cgroups=no-conmon \
		--pod hermes-pod-%i \
		--volume %S/state/dashboard-sockets:/sockets:z \
		--tz=${TIMEZONE} \
		${HERMES_AGENT_SOCKET_IMAGE} \
		-d -d \
		UNIX-LISTEN:/sockets/agent-%i-chat.sock,fork,unlink-early,mode=0660 \
		TCP-CONNECT:127.0.0.1:8080
ExecStop=/usr/bin/podman stop --ignore --time 10 openwebui-socket-%i
ExecStopPost=-/usr/bin/podman rm --force openwebui-socket-%i
TimeoutStopSec=70

[Install]
WantedBy=default.target
