[Unit]
Description=Open WebUI sidecar %i
Requires=hermes-pod@%i.service hermes@%i.service
After=hermes-pod@%i.service hermes@%i.service

[Service]
Environment=PODMAN_SYSTEMD_UNIT=%n
EnvironmentFile=-%S/state/environment
EnvironmentFile=-%S/state/agent_%i.env
WorkingDirectory=%S/state
Restart=on-failure
KillMode=none
Type=notify
NotifyAccess=all
ExecStartPre=/usr/local/bin/runagent discover-smarthost
ExecStartPre=/usr/local/bin/runagent sync-agent-runtime --agent-id %i
ExecStartPre=-/usr/bin/podman rm --force openwebui-%i
ExecStart=runagent /usr/bin/podman run \
		--name openwebui-%i \
		--replace \
		--rm \
		--sdnotify=conmon \
		--cgroups=no-conmon \
		--pod hermes-pod-%i \
		--env-file %S/state/agent_%i.env \
		--env-file %S/state/agent_%i_secrets.env \
		--env PORT=8080 \
		--env WEBUI_AUTH=false \
		--env ENABLE_OPENAI_API=true \
		--env OPENAI_API_BASE_URL=http://127.0.0.1:8642/v1 \
		--tz=${TIMEZONE} \
		${HERMES_AGENT_OPENWEBUI_IMAGE}
ExecStop=/usr/bin/podman stop --ignore --time 10 openwebui-%i
ExecStopPost=-/usr/bin/podman rm --force openwebui-%i
TimeoutStopSec=70

[Install]
WantedBy=default.target
